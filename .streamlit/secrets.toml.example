# Streamlit secrets template. Copy to .streamlit/secrets.toml for LOCAL testing
# (that file is git-ignored). On Streamlit Community Cloud, paste these same
# keys into the app's Settings -> Secrets box instead of using a file.

# Your Anthropic API key (used for text-to-SQL). Required.
ANTHROPIC_API_KEY = "sk-ant-..."

# Shared password gate for the public app. If unset, the app is open (local dev).
APP_PASSWORD = "choose-a-password"

# Optional: cap questions per browser session to limit API spend (default 20).
MAX_QUESTIONS_PER_SESSION = "20"

# Optional: override the model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL = "claude-sonnet-4-6"
