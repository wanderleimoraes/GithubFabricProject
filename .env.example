# Copy to .env and fill in. NEVER commit the real .env.

# SEC EDGAR requires a descriptive User-Agent with contact info (their policy).
SEC_USER_AGENT="SP500 Portfolio Project wanderleimoraes@gmail.com"

# Claude API — used by the LLM extraction layer and the NL Q&A app.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-fable-5"

# Databricks (for dbt + ingestion writes). Leave blank to use local DuckDB.
DATABRICKS_HOST="https://adb-xxxx.azuredatabricks.net"
DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/xxxx"
DATABRICKS_TOKEN="dapi..."
DATABRICKS_CATALOG="sp500"
DATABRICKS_SCHEMA="bronze"

# Local data lake root (development mode)
DATA_DIR="./data"
